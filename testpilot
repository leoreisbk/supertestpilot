#!/usr/bin/env bash
set -euo pipefail

PLATFORM=""
APP_NAME=""
OBJECTIVE=""
API_KEY="${TESTPILOT_API_KEY:-}"
PROVIDER="${TESTPILOT_PROVIDER:-anthropic}"
MAX_STEPS=20
OUTPUT="./report.html"
LANG_CODE="en"
DEVICE_UDID=""   # physical device UDID (optional; uses booted simulator if omitted)
TEAM_ID=""       # Apple Developer Team ID (required for physical device)

COMMAND="${1:-}"
if [[ "$COMMAND" != "analyze" ]]; then
  echo "Usage: ./testpilot analyze --platform ios|android --app <name> --objective <text>"
  echo "       [--device <UDID>] [--team-id <TEAM_ID>] [--provider anthropic|openai|gemini]"
  echo "       [--api-key <key>] [--max-steps <n>] [--output <path>] [--lang en|pt-BR]"
  exit 1
fi
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --platform)  PLATFORM="$2";     shift 2 ;;
    --app)       APP_NAME="$2";     shift 2 ;;
    --objective) OBJECTIVE="$2";    shift 2 ;;
    --api-key)   API_KEY="$2";      shift 2 ;;
    --provider)  PROVIDER="$2";     shift 2 ;;
    --max-steps) MAX_STEPS="$2";    shift 2 ;;
    --output)    OUTPUT="$2";       shift 2 ;;
    --lang)      LANG_CODE="$2";    shift 2 ;;
    --device)    DEVICE_UDID="$2";  shift 2 ;;
    --team-id)   TEAM_ID="$2";      shift 2 ;;
    *) echo "Unknown flag: $1"; exit 1 ;;
  esac
done

# Load .env
if [[ -f ".env" ]]; then
  set -a; source .env; set +a
  API_KEY="${TESTPILOT_API_KEY:-$API_KEY}"
  PROVIDER="${TESTPILOT_PROVIDER:-$PROVIDER}"
  TEAM_ID="${TESTPILOT_TEAM_ID:-$TEAM_ID}"
fi

[[ -z "$PLATFORM" ]]  && { echo "Error: --platform required (ios or android)"; exit 1; }
[[ -z "$APP_NAME" ]]  && { echo "Error: --app required"; exit 1; }
[[ -z "$OBJECTIVE" ]] && { echo "Error: --objective required"; exit 1; }
[[ -z "$API_KEY" ]]   && { echo "Error: API key required (--api-key or TESTPILOT_API_KEY in .env)"; exit 1; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "$PLATFORM" == "ios" ]]; then
  command -v xcrun >/dev/null 2>&1 || { echo "Error: xcrun not found — install Xcode command line tools"; exit 1; }

  # ── Determine target: physical device or simulator ──────────────────────────
  USE_DEVICE=false
  if [[ -n "$DEVICE_UDID" ]]; then
    USE_DEVICE=true
    [[ -z "$TEAM_ID" ]] && { echo "Error: --team-id required when targeting a physical device (or set TESTPILOT_TEAM_ID in .env)"; exit 1; }
    DESTINATION="platform=iOS,id=$DEVICE_UDID"
    echo "Targeting physical device: $DEVICE_UDID"
  else
    BOOTED=$(xcrun simctl list devices | grep "(Booted)" | head -1)
    [[ -z "$BOOTED" ]] && { echo "Error: No booted iOS simulator. Boot one in Xcode or with: xcrun simctl boot <UDID>"; exit 1; }

    BOOTED_UDID=$(xcrun simctl list devices --json | python3 -c "
import json, sys
devs = json.load(sys.stdin)
for runtime, devices in devs.get('devices', {}).items():
    for d in devices:
        if d.get('state') == 'Booted':
            print(d['udid'])
            exit()
")
    [[ -z "$BOOTED_UDID" ]] && { echo "Error: Could not determine booted simulator UDID."; exit 1; }
    DESTINATION="platform=iOS Simulator,id=$BOOTED_UDID"
  fi

  # ── Resolve bundle ID ────────────────────────────────────────────────────────
  echo "Resolving bundle ID for \"$APP_NAME\"..."
  export TP_APP_NAME="$APP_NAME"

  if [[ "$USE_DEVICE" == "true" ]]; then
    # Physical device: list apps via devicectl.
    # devicectl writes a text table to stdout AND JSON to --json-output;
    # using /dev/stdout for both corrupts the JSON stream, so we use a temp file.
    _APPS_JSON=$(mktemp /tmp/tp_apps_XXXXXX.json)
    xcrun devicectl device info apps --device "$DEVICE_UDID" --json-output "$_APPS_JSON" >/dev/null 2>&1 || true
    BUNDLE_ID=$(python3 -c "
import json, sys, os
name_lower = os.environ['TP_APP_NAME'].lower()
with open('$_APPS_JSON') as f:
    data = json.load(f)
apps = data.get('result', {}).get('apps', [])
matches = []
for app in apps:
    bid = app.get('bundleID', '')
    name = app.get('name', bid)
    if name_lower in name.lower() or name_lower in bid.lower():
        matches.append((bid, name))
if len(matches) == 0:
    print('ERROR_no_match', end='')
elif len(matches) == 1:
    print(matches[0][0], end='')
else:
    print('MULTIPLE_' + ','.join(f'{bid}={name}' for bid, name in matches), end='')
" 2>/dev/null || echo "ERROR_no_match")
    rm -f "$_APPS_JSON"
  else
    # Simulator: parse ASCII plist from simctl listapps
    BUNDLE_ID=$(xcrun simctl listapps "$BOOTED_UDID" 2>/dev/null \
      | python3 -c "
import sys, re, os
text = sys.stdin.read()
name_lower = os.environ['TP_APP_NAME'].lower()
matches = []
blocks = re.split(r'\"([^\"]+)\"\s*=\s*\{', text)
i = 1
while i < len(blocks) - 1:
    bid = blocks[i]; body = blocks[i+1]; i += 2
    if '.' not in bid: continue
    dm = re.search(r'CFBundleDisplayName\s*=\s*(?:\"([^\"]*)\"|([A-Za-z0-9 _\-]+))\s*;', body)
    nm = re.search(r'CFBundleName\s*=\s*(?:\"([^\"]*)\"|([A-Za-z0-9 _\-]+))\s*;', body)
    display = (dm.group(1) or dm.group(2)) if dm else ((nm.group(1) or nm.group(2)) if nm else bid)
    if name_lower in display.lower() or name_lower in bid.lower():
        matches.append((bid, display))
if len(matches) == 0:
    print('ERROR_no_match', end='')
elif len(matches) == 1:
    print(matches[0][0], end='')
else:
    print('MULTIPLE_' + ','.join(f'{bid}={name}' for bid, name in matches), end='')
")
  fi

  if [[ "$BUNDLE_ID" == ERROR* ]]; then
    echo "Error: No app matching \"$APP_NAME\" found on the target device."
    exit 1
  fi

  if [[ "$BUNDLE_ID" == MULTIPLE* ]]; then
    echo "Multiple matches. Pick one:"
    IFS=',' read -ra CHOICES <<< "${BUNDLE_ID#MULTIPLE_}"
    select choice in "${CHOICES[@]}"; do BUNDLE_ID="${choice%%=*}"; break; done
  fi

  echo "Found: $BUNDLE_ID"

  # ── Build SDK ────────────────────────────────────────────────────────────────
  echo "Building SDK..."
  (cd "$SCRIPT_DIR" && scripts/build_ios_sdk.sh) >/dev/null 2>&1 \
    || { echo "Error: SDK build failed. Run scripts/build_ios_sdk.sh manually for details."; exit 1; }

  # ── Prepare test file ────────────────────────────────────────────────────────
  DERIVED_DATA=$(mktemp -d)
  TEST_SWIFT="$SCRIPT_DIR/harness/AnalystTests/AnalystTests.swift"
  TEST_SWIFT_BACKUP="$SCRIPT_DIR/harness/AnalystTests/AnalystTests.swift.bak"
  cp "$TEST_SWIFT" "$TEST_SWIFT_BACKUP"
  trap 'cp "$TEST_SWIFT_BACKUP" "$TEST_SWIFT"; rm -f "$TEST_SWIFT_BACKUP"; [[ -f "$DERIVED_DATA/xcodebuild.log" ]] && cp "$DERIVED_DATA/xcodebuild.log" /tmp/testpilot_last_xcodebuild.log; rm -rf "$DERIVED_DATA"' EXIT

  _swift_esc() {
    local s="$1"
    s="${s//\\/\\\\}"    # backslash → \\
    s="${s//\"/\\\"}"    # " → \"
    s="${s//$'\n'/\\n}"  # newline → \n (keeps Swift string on one line)
    s="${s//$'\r'/}"     # strip carriage returns
    printf '%s' "$s"
  }
  API_KEY_ESC=$(_swift_esc "$API_KEY")
  PROVIDER_ESC=$(_swift_esc "$PROVIDER")
  OBJECTIVE_ESC=$(_swift_esc "$OBJECTIVE")
  LANG_ESC=$(_swift_esc "$LANG_CODE")
  BUNDLE_ID_OPT="nil"
  [[ -n "$BUNDLE_ID" ]] && BUNDLE_ID_OPT="\"$(_swift_esc "$BUNDLE_ID")\""

  cat > "$TEST_SWIFT" <<SWIFT
// This file is overwritten by the testpilot CLI before each run.
// Do not edit manually.
import XCTest
import TestPilotShared

class AnalystTests: XCTestCase {
    func testAnalyze() async throws {
        let provider: AIProvider = "$PROVIDER_ESC" == "openai" ? .openai : ("$PROVIDER_ESC" == "gemini" ? .gemini : .anthropic)
        let config = ConfigBuilder()
            .provider(provider: provider)
            .apiKey(key: "$API_KEY_ESC")
            .maxSteps(steps: $MAX_STEPS)
            .language(lang: "$LANG_ESC")
            .build()
        let analyst = AnalystIOS(config: config)
        let _ = try await analyst.run(
            objective: "$OBJECTIVE_ESC",
            bundleId: $BUNDLE_ID_OPT
        )
    }
}
SWIFT

  # ── Run xcodebuild ───────────────────────────────────────────────────────────
  echo "Running analysis..."
  XCODE_LOG="$DERIVED_DATA/xcodebuild.log"

  XCODE_EXTRA_ARGS=()
  if [[ "$USE_DEVICE" == "true" ]]; then
    XCODE_EXTRA_ARGS+=(-allowProvisioningUpdates "DEVELOPMENT_TEAM=$TEAM_ID")
  fi

  LOG=$(xcodebuild test \
          -project "$SCRIPT_DIR/harness/Harness.xcodeproj" \
          -scheme AnalystTests \
          -destination "$DESTINATION" \
          -derivedDataPath "$DERIVED_DATA" \
          ${XCODE_EXTRA_ARGS[@]+"${XCODE_EXTRA_ARGS[@]}"} \
          2>&1 || true)
  echo "$LOG" > "$XCODE_LOG"

  REPORT_PATH=$(echo "$LOG" | grep "TESTPILOT_REPORT_PATH=" | tail -1 | sed 's/.*TESTPILOT_REPORT_PATH=//' || true)

  if [[ -z "$REPORT_PATH" ]]; then
    echo "Error: Analysis produced no report. Test likely failed."
    echo "Xcodebuild log saved to: $XCODE_LOG"
    echo "--- Key lines ---"
    grep -E "error:|[Ee]xception|TESTPILOT|authentication|TEST (PASSED|FAILED)" "$XCODE_LOG" | grep -v "at [0-9]" | head -30 || true
    exit 1
  fi

  # ── Copy report to host ──────────────────────────────────────────────────────
  echo "Copying report..."
  if [[ "$USE_DEVICE" == "true" ]]; then
    xcrun devicectl device copy off \
      --device "$DEVICE_UDID" \
      --source "$REPORT_PATH" \
      --destination "$OUTPUT" \
      || { echo "Error: Could not copy report from device. Path tried: $REPORT_PATH"; exit 1; }
  else
    cp "$REPORT_PATH" "$OUTPUT" \
      || { echo "Error: Could not copy report from simulator. Path tried: $REPORT_PATH"; exit 1; }
  fi

  echo "Report written to: $OUTPUT"
  open "$OUTPUT"

elif [[ "$PLATFORM" == "android" ]]; then
  command -v adb >/dev/null 2>&1 || { echo "Error: adb not found — install Android SDK Platform Tools"; exit 1; }

  DEVICES=$(adb devices | grep -v "^List" | grep -c "device$" || true)
  [[ "$DEVICES" == "0" ]] && { echo "Error: No Android device/emulator connected."; exit 1; }

  echo "Resolving package for \"$APP_NAME\"..."
  PACKAGE=$(adb shell pm list packages -3 2>/dev/null | sed 's/package://' | grep -i "$APP_NAME" | head -1 | tr -d '\r')
  [[ -z "$PACKAGE" ]] && { echo "Error: No package matching \"$APP_NAME\". Run: adb shell pm list packages -3"; exit 1; }
  echo "Found: $PACKAGE"

  echo "Building SDK..."
  (cd "$SCRIPT_DIR/sdk" && ./gradlew testpilot:assembleDebug) >/dev/null 2>&1 \
    || { echo "Error: AAR build failed."; exit 1; }

  echo "Running analysis..."
  INSTRUMENT_OUTPUT=$(adb shell am instrument \
    -e class "co.work.testpilot.analyst.AnalystAndroid" \
    -e TESTPILOT_API_KEY "$API_KEY" \
    -e TESTPILOT_PROVIDER "$PROVIDER" \
    -e TESTPILOT_OBJECTIVE "$OBJECTIVE" \
    -e TESTPILOT_MAX_STEPS "$MAX_STEPS" \
    -w "$PACKAGE/androidx.test.runner.AndroidJUnitRunner" 2>&1 || true)

  if echo "$INSTRUMENT_OUTPUT" | grep -q "FAILURES\|Error"; then
    echo "Error: Analysis failed. Output:"
    echo "$INSTRUMENT_OUTPUT"
    exit 1
  fi

  echo "Pulling report..."
  adb pull "/sdcard/Android/data/$PACKAGE/files/testpilot_report.html" "$OUTPUT" \
    || { echo "Error: Could not pull report from device."; exit 1; }

  echo "Report written to: $OUTPUT"
  open "$OUTPUT" 2>/dev/null || echo "Open $OUTPUT in your browser."

else
  echo "Error: Unknown platform \"$PLATFORM\". Use ios or android."
  exit 1
fi
