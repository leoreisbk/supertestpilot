#!/usr/bin/env bash
set -euo pipefail

PLATFORM=""
APP_NAME=""
URL=""
USERNAME=""
PASSWORD=""
OBJECTIVE=""
API_KEY="${TESTPILOT_API_KEY:-}"
PROVIDER="${TESTPILOT_PROVIDER:-anthropic}"
MAX_STEPS=40
OUTPUT="./report.html"
LANG_CODE="en"
DEVICE_UDID=""   # physical device UDID (optional; uses booted simulator if omitted)
TEAM_ID=""       # Apple Developer Team ID (required for physical device)
BUNDLE_ID_OVERRIDE=""  # skip app-name lookup and use this bundle ID directly
PERSONA_FILE=""

COMMAND="${1:-}"
if [[ "$COMMAND" != "analyze" && "$COMMAND" != "test" && "$COMMAND" != "web-login" ]]; then
  echo "Usage: ./testpilot analyze --platform ios|android --app <name> --objective <text>"
  echo "       ./testpilot test    --platform ios|android --app <name> --objective <text>"
  echo "       [--device <UDID>] [--team-id <TEAM_ID>] [--bundle-id <BUNDLE_ID>]"
  echo "       [--provider anthropic|openai|gemini]"
  echo "       [--api-key <key>] [--max-steps <n>] [--output <path>] [--lang en|pt-BR]"
  echo ""
  echo "       ./testpilot analyze --platform web --url <URL> --objective <text>"
  echo "       ./testpilot test    --platform web --url <URL> --objective <text>"
  echo "       [--username <user>] [--password <pass>]"
  echo "       [--provider anthropic|openai|gemini] [--api-key <key>] [--max-steps <n>] [--lang en|pt-BR]"
  echo ""
  echo "       ./testpilot web-login --url <URL>"
  exit 1
fi
TEST_MODE=false
[[ "$COMMAND" == "test" ]] && TEST_MODE=true
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --platform)  PLATFORM="$2";     shift 2 ;;
    --app)       APP_NAME="$2";     shift 2 ;;
    --url)       URL="$2";          shift 2 ;;
    --username)  USERNAME="$2";     shift 2 ;;
    --password)  PASSWORD="$2";     shift 2 ;;
    --objective) OBJECTIVE="$2";    shift 2 ;;
    --persona)   PERSONA_FILE="$2"; shift 2 ;;
    --api-key)   API_KEY="$2";      shift 2 ;;
    --provider)  PROVIDER="$2";     shift 2 ;;
    --max-steps) MAX_STEPS="$2";    shift 2 ;;
    --output)    OUTPUT="$2";       shift 2 ;;
    --lang)      LANG_CODE="$2";    shift 2 ;;
    --device)    DEVICE_UDID="$2";         shift 2 ;;
    --team-id)   TEAM_ID="$2";            shift 2 ;;
    --bundle-id) BUNDLE_ID_OVERRIDE="$2"; shift 2 ;;
    *) echo "Unknown flag: $1"; exit 1 ;;
  esac
done

# Load .env
if [[ -f ".env" ]]; then
  set -a; source .env; set +a
  API_KEY="${TESTPILOT_API_KEY:-$API_KEY}"
  PROVIDER="${TESTPILOT_PROVIDER:-$PROVIDER}"
  TEAM_ID="${TESTPILOT_TEAM_ID:-$TEAM_ID}"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TESTPILOT_CACHE="$HOME/.testpilot"
MANIFEST_URL="https://github.com/leoreisbk/supertestpilot/releases/latest/download/artifacts-manifest.json"

_ensure_artifact() {
  local platform="$1"
  local dest="$TESTPILOT_CACHE/$platform"

  # If artifact already exists locally, use it (no version check in CLI)
  case "$platform" in
    ios)
      [[ -d "$dest/TestPilotShared.xcframework" && -d "$TESTPILOT_CACHE/harness/Harness.xcodeproj" ]] && return 0
      ;;
    web)
      [[ -f "$dest/testpilot-web.jar" && -x "$dest/jre/bin/java" ]] && return 0
      ;;
  esac

  echo "Downloading $platform components..."

  # Fetch manifest
  local manifest
  manifest=$(curl -fsSL "$MANIFEST_URL" 2>/dev/null) \
    || { echo "Error: Could not download artifacts manifest. Check your internet connection."; exit 1; }

  local url sha256
  url=$(echo "$manifest" | python3 -c "import json,sys; m=json.load(sys.stdin); print(m['artifacts']['$platform']['url'])")
  sha256=$(echo "$manifest" | python3 -c "import json,sys; m=json.load(sys.stdin); print(m['artifacts']['$platform']['sha256'])")

  [[ -z "$url" ]] && { echo "Error: No artifact URL for platform $platform in manifest."; exit 1; }

  # Download to temp file
  local tmp
  tmp=$(mktemp /tmp/testpilot_artifact_XXXXXX)
  trap 'rm -f "$tmp"' RETURN
  curl -fL --progress-bar "$url" -o "$tmp" \
    || { echo "Error: Failed to download $url"; exit 1; }

  # Verify SHA256
  local actual
  actual=$(shasum -a 256 "$tmp" | awk '{print $1}')
  [[ "$actual" == "$sha256" ]] || { echo "Error: SHA256 mismatch for $platform artifact."; exit 1; }

  # Unpack (ios artifact contains ios/ and harness/ subdirs — unpack to cache root)
  local unpack_dest="$dest"
  [[ "$platform" == "ios" ]] && unpack_dest="$TESTPILOT_CACHE"
  mkdir -p "$unpack_dest"
  case "$url" in
    *.zip)    unzip -q "$tmp" -d "$unpack_dest" ;;
    *.tar.gz) tar -xzf "$tmp" -C "$unpack_dest" ;;
  esac

  echo "$sha256" > "$dest/.sha256"
  echo "$platform components ready."
}

# Resolve OUTPUT to an absolute path so it's correct regardless of working directory
OUTPUT="$(cd "$(dirname "$OUTPUT")" 2>/dev/null && pwd)/$(basename "$OUTPUT")" 2>/dev/null || OUTPUT="$(pwd)/$(basename "$OUTPUT")"

# ── web-login: establish browser session without running a test ──────────────
if [[ "$COMMAND" == "web-login" ]]; then
  [[ -z "$URL" ]] && { echo "Error: --url required for web-login"; exit 1; }

  _ensure_artifact web
  JAVA_BIN="$TESTPILOT_CACHE/web/jre/bin/java"
  WEB_JAR="$TESTPILOT_CACHE/web/testpilot-web.jar"

  (
    export TESTPILOT_MODE="login"
    export TESTPILOT_WEB_URL="$URL"
    export TESTPILOT_API_KEY="${API_KEY:-dummy}"
    "$JAVA_BIN" -jar "$WEB_JAR"
  )
  exit $?
fi

[[ -z "$PLATFORM" ]]  && { echo "Error: --platform required (ios, android, or web)"; exit 1; }
# Objective is optional for analyze when a persona is provided; fall back to a generic goal
if [[ -z "$OBJECTIVE" ]]; then
  if [[ "$COMMAND" == "analyze" ]] && [[ -n "$PERSONA_FILE" ]]; then
    OBJECTIVE="Explore the app from the perspective of the persona."
  else
    echo "Error: --objective required"; exit 1
  fi
fi
if [[ -n "$PERSONA_FILE" ]] && [[ ! -f "$PERSONA_FILE" ]]; then
  echo "Error: persona file not found: $PERSONA_FILE"; exit 1
fi
[[ -z "$API_KEY" ]]   && { echo "Error: API key required (--api-key or TESTPILOT_API_KEY in .env)"; exit 1; }

if [[ "$PLATFORM" == "web" ]]; then
  [[ -z "$URL" ]] && { echo "Error: --url required for --platform web"; exit 1; }
else
  [[ -z "$APP_NAME" && -z "$BUNDLE_ID_OVERRIDE" ]] && { echo "Error: --app or --bundle-id required for --platform $PLATFORM"; exit 1; }
fi

if [[ "$PLATFORM" == "ios" ]]; then
  command -v xcrun >/dev/null 2>&1 || { echo "Error: xcrun not found — install Xcode command line tools"; exit 1; }

  # ── Determine target: physical device or simulator ──────────────────────────
  USE_DEVICE=false
  if [[ -n "$DEVICE_UDID" ]]; then
    # Check if the UDID belongs to a simulator
    IS_SIM=$(xcrun simctl list devices --json 2>/dev/null | python3 -c "
import json, sys
devs = json.load(sys.stdin)
for runtime, devices in devs.get('devices', {}).items():
    for d in devices:
        if d.get('udid') == '$DEVICE_UDID':
            print('yes')
            exit()
print('no')
" 2>/dev/null)
    if [[ "$IS_SIM" == "yes" ]]; then
      BOOTED_UDID="$DEVICE_UDID"
      DESTINATION="platform=iOS Simulator,id=$DEVICE_UDID"
      echo "Targeting simulator: $DEVICE_UDID"
    else
      USE_DEVICE=true
      [[ -z "$TEAM_ID" ]] && { echo "Error: --team-id required when targeting a physical device (or set TESTPILOT_TEAM_ID in .env)"; exit 1; }
      DESTINATION="platform=iOS,id=$DEVICE_UDID"
      echo "Targeting physical device: $DEVICE_UDID"
    fi
  else
    BOOTED=$(xcrun simctl list devices | grep "(Booted)" | head -1)
    [[ -z "$BOOTED" ]] && { echo "Error: No booted iOS simulator. Boot one in Xcode or with: xcrun simctl boot <UDID>"; exit 1; }

    BOOTED_UDID=$(xcrun simctl list devices --json | python3 -c "
import json, sys
devs = json.load(sys.stdin)
for runtime, devices in devs.get('devices', {}).items():
    for d in devices:
        if d.get('state') == 'Booted':
            print(d['udid'])
            exit()
")
    [[ -z "$BOOTED_UDID" ]] && { echo "Error: Could not determine booted simulator UDID."; exit 1; }
    DESTINATION="platform=iOS Simulator,id=$BOOTED_UDID"
  fi

  # ── Resolve bundle ID ────────────────────────────────────────────────────────
  if [[ -n "$BUNDLE_ID_OVERRIDE" ]]; then
    BUNDLE_ID="$BUNDLE_ID_OVERRIDE"
    echo "Using bundle ID: $BUNDLE_ID"
  else
  echo "Resolving bundle ID for \"$APP_NAME\"..."
  export TP_APP_NAME="$APP_NAME"

  if [[ "$USE_DEVICE" == "true" ]]; then
    # Physical device: list apps via devicectl.
    # devicectl writes a text table to stdout AND JSON to --json-output;
    # using /dev/stdout for both corrupts the JSON stream, so we use a temp file.
    _APPS_JSON=$(mktemp /tmp/tp_apps_XXXXXX.json)
    xcrun devicectl device info apps --device "$DEVICE_UDID" --json-output "$_APPS_JSON" >/dev/null 2>&1 || true
    BUNDLE_ID=$(python3 -c "
import json, sys, os
name_lower = os.environ['TP_APP_NAME'].lower()
with open('$_APPS_JSON') as f:
    data = json.load(f)
apps = data.get('result', {}).get('apps', [])
matches = []
for app in apps:
    bid = app.get('bundleIdentifier', app.get('bundleID', ''))
    name = app.get('name', bid)
    if name_lower in name.lower() or name_lower in bid.lower():
        matches.append((bid, name))
if len(matches) == 0:
    print('ERROR_no_match', end='')
elif len(matches) == 1:
    print(matches[0][0], end='')
else:
    print('MULTIPLE_' + ','.join(f'{bid}={name}' for bid, name in matches), end='')
" 2>/dev/null || echo "ERROR_no_match")
    rm -f "$_APPS_JSON"
    # Fallback: system apps not listed by devicectl
    if [[ "$BUNDLE_ID" == "ERROR_no_match" ]]; then
      BUNDLE_ID=$(python3 -c "
import os
name_lower = os.environ['TP_APP_NAME'].lower()
system_apps = {
  'fitness': 'com.apple.Fitness',
  'health': 'com.apple.Health',
  'maps': 'com.apple.Maps',
  'settings': 'com.apple.Preferences',
  'safari': 'com.apple.mobilesafari',
  'messages': 'com.apple.MobileSMS',
  'mail': 'com.apple.mobilemail',
  'photos': 'com.apple.mobileslideshow',
  'camera': 'com.apple.camera',
  'calendar': 'com.apple.mobilecal',
  'contacts': 'com.apple.MobileAddressBook',
  'notes': 'com.apple.mobilenotes',
  'reminders': 'com.apple.reminders',
  'clock': 'com.apple.mobiletimer',
  'weather': 'com.apple.weather',
  'wallet': 'com.apple.Passbook',
  'app store': 'com.apple.AppStore',
  'music': 'com.apple.Music',
  'podcasts': 'com.apple.podcasts',
  'tv': 'com.apple.tv',
  'files': 'com.apple.DocumentsApp',
}
match = next((bid for key, bid in system_apps.items() if name_lower in key or key in name_lower), None)
print(match if match else 'ERROR_no_match', end='')
" 2>/dev/null || echo "ERROR_no_match")
    fi
  else
    # Simulator: parse ASCII plist from simctl listapps
    BUNDLE_ID=$(xcrun simctl listapps "$BOOTED_UDID" 2>/dev/null \
      | python3 -c "
import sys, re, os
text = sys.stdin.read()
name_lower = os.environ['TP_APP_NAME'].lower()
matches = []
blocks = re.split(r'\"([^\"]+)\"\s*=\s*\{', text)
i = 1
while i < len(blocks) - 1:
    bid = blocks[i]; body = blocks[i+1]; i += 2
    if '.' not in bid: continue
    dm = re.search(r'CFBundleDisplayName\s*=\s*(?:\"([^\"]*)\"|([A-Za-z0-9 _\-]+))\s*;', body)
    nm = re.search(r'CFBundleName\s*=\s*(?:\"([^\"]*)\"|([A-Za-z0-9 _\-]+))\s*;', body)
    display = (dm.group(1) or dm.group(2)) if dm else ((nm.group(1) or nm.group(2)) if nm else bid)
    if name_lower in display.lower() or name_lower in bid.lower():
        matches.append((bid, display))
if len(matches) == 0:
    print('ERROR_no_match', end='')
elif len(matches) == 1:
    print(matches[0][0], end='')
else:
    print('MULTIPLE_' + ','.join(f'{bid}={name}' for bid, name in matches), end='')
")
  fi

  if [[ "$BUNDLE_ID" == ERROR* ]]; then
    echo "Error: No app matching \"$APP_NAME\" found on the target device."
    exit 1
  fi

  if [[ "$BUNDLE_ID" == MULTIPLE* ]]; then
    echo "Multiple matches. Pick one:"
    IFS=',' read -ra CHOICES <<< "${BUNDLE_ID#MULTIPLE_}"
    select choice in "${CHOICES[@]}"; do BUNDLE_ID="${choice%%=*}"; break; done
  fi

  fi  # end of bundle ID resolution (skipped when --bundle-id is provided)

  echo "Using: $BUNDLE_ID"

  # ── Ensure artifacts present ─────────────────────────────────────────────────
  _ensure_artifact ios

  # ── Prepare test file ────────────────────────────────────────────────────────
  DERIVED_DATA=$(mktemp -d)
  TEST_SWIFT="$TESTPILOT_CACHE/harness/AnalystTests/AnalystTests.swift"
  mkdir -p "$(dirname "$TEST_SWIFT")"
  trap '[[ -f "$DERIVED_DATA/xcodebuild.log" ]] && cp "$DERIVED_DATA/xcodebuild.log" /tmp/testpilot_last_xcodebuild.log; rm -rf "$DERIVED_DATA"' EXIT

  _swift_esc() {
    local s="$1"
    s="${s//\\/\\\\}"    # backslash → \\
    s="${s//\"/\\\"}"    # " → \"
    s="${s//$'\n'/\\n}"  # newline → \n (keeps Swift string on one line)
    s="${s//$'\r'/}"     # strip carriage returns
    printf '%s' "$s"
  }
  PROVIDER_ESC=$(_swift_esc "$PROVIDER")
  OBJECTIVE_ESC=$(_swift_esc "$OBJECTIVE")
  LANG_ESC=$(_swift_esc "$LANG_CODE")
  BUNDLE_ID_OPT="nil"
  [[ -n "$BUNDLE_ID" ]] && BUNDLE_ID_OPT="\"$(_swift_esc "$BUNDLE_ID")\""

  # XCUIApplication(bundleIdentifier:) calls XCUIWaitAndAssert internally on Xcode 26+,
  # which conflicts with the async test runner's outer XCTWaiter. Creating it in the
  # synchronous setUp() avoids this — setUp() runs before the async waiter is pushed.
  XCAPP_INIT="XCUIApplication()"
  [[ "$BUNDLE_ID_OPT" != "nil" ]] && XCAPP_INIT="XCUIApplication(bundleIdentifier: $BUNDLE_ID_OPT)"

  # Credentials are passed via -testenv at xcodebuild time and read from the
  # process environment at runtime — never stored as literals in the Swift file.
  CREDENTIALS_BLOCK='
        let env = ProcessInfo.processInfo.environment
        let apiKey   = env["TESTPILOT_API_KEY"] ?? ""
        let username: String? = env["TESTPILOT_USERNAME"].flatMap { $0.isEmpty ? nil : $0 }
        let password: String? = env["TESTPILOT_PASSWORD"].flatMap { $0.isEmpty ? nil : $0 }'

  # Persona is only used in analyze mode
  PERSONA_BLOCK='        let persona: String? = nil'
  if [[ -n "$PERSONA_FILE" ]] && [[ "$TEST_MODE" != "true" ]]; then
    PERSONA_BLOCK='        let personaB64 = env["TESTPILOT_PERSONA_B64"]
        let persona: String? = personaB64.flatMap { Data(base64Encoded: $0) }
            .flatMap { String(data: $0, encoding: .utf8) }'
  fi

if [[ "$TEST_MODE" == "true" ]]; then
  cat > "$TEST_SWIFT" <<SWIFT
// This file is overwritten by the testpilot CLI before each run.
// Do not edit manually.
import XCTest
import TestPilotShared

class AnalystTests: XCTestCase {
    var analyst: TestAnalystIOS!
    var xcApp: XCUIApplication!
    var username: String?
    var password: String?

    override func setUp() {
        super.setUp()
        xcApp = $XCAPP_INIT
        let provider: AIProvider = "$PROVIDER_ESC" == "openai" ? .openai : ("$PROVIDER_ESC" == "gemini" ? .gemini : .anthropic)
$CREDENTIALS_BLOCK
        let config = ConfigBuilder()
            .provider(provider: provider)
            .apiKey(key: apiKey)
            .maxSteps(steps: $MAX_STEPS)
            .language(lang: "$LANG_ESC")
            .build()
        analyst = TestAnalystIOS(config: config)
    }

    func testAnalyze() async throws {
        let _ = try await analyst.run(
            objective: "$OBJECTIVE_ESC",
            xcApp: xcApp,
            username: username,
            password: password
        )
    }
}
SWIFT
else
  cat > "$TEST_SWIFT" <<SWIFT
// This file is overwritten by the testpilot CLI before each run.
// Do not edit manually.
import XCTest
import TestPilotShared

class AnalystTests: XCTestCase {
    var analyst: AnalystIOS!
    var xcApp: XCUIApplication!
    var username: String?
    var password: String?

    override func setUp() {
        super.setUp()
        xcApp = $XCAPP_INIT
        let provider: AIProvider = "$PROVIDER_ESC" == "openai" ? .openai : ("$PROVIDER_ESC" == "gemini" ? .gemini : .anthropic)
$CREDENTIALS_BLOCK
$PERSONA_BLOCK
        let config = ConfigBuilder()
            .provider(provider: provider)
            .apiKey(key: apiKey)
            .maxSteps(steps: $MAX_STEPS)
            .language(lang: "$LANG_ESC")
            .persona(markdown: persona)
            .build()
        analyst = AnalystIOS(config: config)
    }

    func testAnalyze() async throws {
        let _ = try await analyst.run(
            objective: "$OBJECTIVE_ESC",
            xcApp: xcApp,
            username: username,
            password: password
        )
    }
}
SWIFT
fi

  # ── Run xcodebuild ───────────────────────────────────────────────────────────
  if [[ "$TEST_MODE" == "true" ]]; then
    echo "Running test..."
  else
    echo "Running analysis..."
  fi
  XCODE_LOG="$DERIVED_DATA/xcodebuild.log"

  XCODE_EXTRA_ARGS=()
  if [[ "$USE_DEVICE" == "true" ]]; then
    XCODE_EXTRA_ARGS+=(-allowProvisioningUpdates "DEVELOPMENT_TEAM=$TEAM_ID")
  fi
  # Pass credentials via TEST_RUNNER_ prefix — XCTest strips the prefix automatically,
  # so the generated Swift reads env["TESTPILOT_API_KEY"] as usual.
  # (-testenv was removed in Xcode 26; TEST_RUNNER_ is the supported alternative.)
  export TEST_RUNNER_TESTPILOT_API_KEY="$API_KEY"
  [[ -n "$USERNAME" ]] && export TEST_RUNNER_TESTPILOT_USERNAME="$USERNAME"
  [[ -n "$PASSWORD" ]] && export TEST_RUNNER_TESTPILOT_PASSWORD="$PASSWORD"
  if [[ -n "$PERSONA_FILE" ]] && [[ "$TEST_MODE" != "true" ]]; then
    export TEST_RUNNER_TESTPILOT_PERSONA_B64=$(base64 < "$PERSONA_FILE")
  fi

  # Stream xcodebuild output in real-time: emit TESTPILOT_STEP/RESULT markers as
  # they appear so the macOS app can update its UI without waiting for completion.
  xcodebuild test \
      -project "$TESTPILOT_CACHE/harness/Harness.xcodeproj" \
      -scheme AnalystTests \
      -destination "$DESTINATION" \
      -derivedDataPath "$DERIVED_DATA" \
      ${XCODE_EXTRA_ARGS[@]+"${XCODE_EXTRA_ARGS[@]}"} \
      2>&1 | tee "$XCODE_LOG" | while IFS= read -r line; do
    if [[ "$line" == *"TESTPILOT_STEP: "* ]]; then
      echo "TESTPILOT_STEP: ${line#*TESTPILOT_STEP: }"
    elif [[ "$line" == *"TESTPILOT_RESULT: "* ]]; then
      echo "TESTPILOT_RESULT: ${line#*TESTPILOT_RESULT: }"
    fi
  done || true
  LOG=$(cat "$XCODE_LOG")

  if [[ "$TEST_MODE" == "true" ]]; then
    RESULT_LINE=$(echo "$LOG" | grep "TESTPILOT_RESULT: " | tail -1 | sed 's/.*TESTPILOT_RESULT: //' || true)

    if [[ -z "$RESULT_LINE" ]]; then
      echo "Error: Test produced no result — the test likely failed to start."
      if grep -qi "Incorrect API key\|invalid_api_key\|AuthenticationError\|authentication_error\|401 Unauthorized" "$XCODE_LOG" 2>/dev/null; then
        echo "Hint: Check your API key — authentication error detected."
      elif grep -qi "keyboard focus\|synthesize event" "$XCODE_LOG" 2>/dev/null; then
        echo "Hint: A text field interaction failed. Try running again — the AI may choose a different action."
      elif grep -qi "No booted\|device not found\|Unable to find" "$XCODE_LOG" 2>/dev/null; then
        echo "Hint: Device not found. Run: xcrun simctl list devices booted"
      elif grep -qi "does not exist\|bundle not found\|could not be launched" "$XCODE_LOG" 2>/dev/null; then
        echo "Hint: App not found on device. Check --app matches the installed app name."
      fi
      echo "Log saved to: $XCODE_LOG"
      echo "--- Key lines ---"
      grep -E "error:|[Ee]xception|authentication_error|TEST (PASSED|FAILED)" "$XCODE_LOG" | grep -v "at [0-9]" | head -30 || true
      exit 1
    fi

    if [[ "$RESULT_LINE" == PASS* ]]; then
      REASON="${RESULT_LINE#PASS }"
      echo ""
      echo "PASSED: $REASON"
      exit 0
    else
      REASON="${RESULT_LINE#FAIL }"
      echo ""
      echo "FAILED: $REASON"
      exit 1
    fi
  else
    REPORT_PATH=$(echo "$LOG" | grep "TESTPILOT_REPORT_PATH=" | tail -1 | sed 's/.*TESTPILOT_REPORT_PATH=//' || true)

    if [[ -z "$REPORT_PATH" ]]; then
      echo "Error: Analysis produced no report — the run likely failed to start."
      if grep -qi "Incorrect API key\|invalid_api_key\|AuthenticationError\|authentication_error\|401 Unauthorized" "$XCODE_LOG" 2>/dev/null; then
        echo "Hint: Check your API key — authentication error detected."
      elif grep -qi "keyboard focus\|synthesize event" "$XCODE_LOG" 2>/dev/null; then
        echo "Hint: A text field interaction failed. Try running again — the AI may choose a different action."
      elif grep -qi "No booted\|device not found\|Unable to find" "$XCODE_LOG" 2>/dev/null; then
        echo "Hint: Device not found. Run: xcrun simctl list devices booted"
      elif grep -qi "does not exist\|bundle not found\|could not be launched" "$XCODE_LOG" 2>/dev/null; then
        echo "Hint: App not found on device. Check --app matches the installed app name."
      fi
      echo "Log saved to: $XCODE_LOG"
      echo "--- Key lines ---"
      grep -E "error:|[Ee]xception|authentication_error|TEST (PASSED|FAILED)" "$XCODE_LOG" | grep -v "at [0-9]" | head -30 || true
      exit 1
    fi

    # ── Extract report from log ──────────────────────────────────────────────────
    echo "Extracting report..."
    if [[ "$USE_DEVICE" == "true" ]]; then
      python3 -c "
import sys
log = open('$XCODE_LOG').read()
start = log.find('TESTPILOT_REPORT_START\n')
end   = log.find('\nTESTPILOT_REPORT_END', start)
if start == -1 or end == -1:
    sys.exit(1)
html = log[start + len('TESTPILOT_REPORT_START\n'):end]
open('$OUTPUT', 'w').write(html)
" || { echo "Error: Could not extract report from xcodebuild log."; exit 1; }
    else
      cp "$REPORT_PATH" "$OUTPUT" \
        || { echo "Error: Could not copy report from simulator. Path tried: $REPORT_PATH"; exit 1; }
    fi

    echo "Report written to: $OUTPUT"
    open "$OUTPUT"
  fi

elif [[ "$PLATFORM" == "android" ]]; then
  command -v adb >/dev/null 2>&1 || { echo "Error: adb not found — install Android SDK Platform Tools"; exit 1; }

  DEVICES=$(adb devices | grep -v "^List" | grep -c "device$" || true)
  [[ "$DEVICES" == "0" ]] && { echo "Error: No Android device/emulator connected."; exit 1; }

  echo "Resolving package for \"$APP_NAME\"..."
  PACKAGE=$(adb shell pm list packages -3 2>/dev/null | sed 's/package://' | grep -i "$APP_NAME" | head -1 | tr -d '\r')
  [[ -z "$PACKAGE" ]] && { echo "Error: No package matching \"$APP_NAME\". Run: adb shell pm list packages -3"; exit 1; }
  echo "Found: $PACKAGE"

  echo "Building SDK..."
  (cd "$SCRIPT_DIR/sdk" && ./gradlew testpilot:assembleDebug) >/dev/null 2>&1 \
    || { echo "Error: AAR build failed."; exit 1; }

  if [[ "$TEST_MODE" == "true" ]]; then
    echo "Running test..."
    INSTRUMENT_OUTPUT=$(adb shell am instrument \
      -e class "co.work.testpilot.analyst.TestAnalystAndroid" \
      -e TESTPILOT_API_KEY "$API_KEY" \
      -e TESTPILOT_PROVIDER "$PROVIDER" \
      -e TESTPILOT_OBJECTIVE "$OBJECTIVE" \
      -e TESTPILOT_MAX_STEPS "$MAX_STEPS" \
      -e TESTPILOT_USERNAME "$USERNAME" \
      -e TESTPILOT_PASSWORD "$PASSWORD" \
      -w "$PACKAGE/androidx.test.runner.AndroidJUnitRunner" 2>&1 || true)

    RESULT_LINE=$(echo "$INSTRUMENT_OUTPUT" | grep "TESTPILOT_RESULT: " | tail -1 | sed 's/.*TESTPILOT_RESULT: //' || true)
    # Echo steps in real-time equivalent (already captured, print them now)
    echo "$INSTRUMENT_OUTPUT" | grep "TESTPILOT_STEP: " | sed 's/.*TESTPILOT_STEP: /TESTPILOT_STEP: /'

    if [[ -z "$RESULT_LINE" ]]; then
      echo "Error: Test produced no result. The run likely failed to start."
      if echo "$INSTRUMENT_OUTPUT" | grep -qi "authentication\|unauthorized\|api key\|401"; then
        echo "Hint: Check your API key — authentication failed."
      elif echo "$INSTRUMENT_OUTPUT" | grep -qi "no such file\|ClassNotFoundException\|NoClassDefFound"; then
        echo "Hint: App may not have the TestPilot SDK installed. Check your build."
      elif echo "$INSTRUMENT_OUTPUT" | grep -qi "INSTRUMENTATION_ABORTED\|process crashed"; then
        echo "Hint: Instrumentation was aborted. Try: adb shell am force-stop $PACKAGE"
      fi
      echo "--- Output ---"
      echo "$INSTRUMENT_OUTPUT"
      exit 1
    fi

    if [[ "$RESULT_LINE" == PASS* ]]; then
      echo ""
      echo "PASSED: ${RESULT_LINE#PASS }"
      exit 0
    else
      echo ""
      echo "FAILED: ${RESULT_LINE#FAIL }"
      exit 1
    fi
  else
    echo "Running analysis..."
    INSTRUMENT_OUTPUT=$(adb shell am instrument \
      -e class "co.work.testpilot.analyst.AnalystAndroid" \
      -e TESTPILOT_API_KEY "$API_KEY" \
      -e TESTPILOT_PROVIDER "$PROVIDER" \
      -e TESTPILOT_OBJECTIVE "$OBJECTIVE" \
      -e TESTPILOT_MAX_STEPS "$MAX_STEPS" \
      -e TESTPILOT_USERNAME "$USERNAME" \
      -e TESTPILOT_PASSWORD "$PASSWORD" \
      -w "$PACKAGE/androidx.test.runner.AndroidJUnitRunner" 2>&1 || true)

    if echo "$INSTRUMENT_OUTPUT" | grep -q "FAILURES\|Error"; then
      echo "Error: Analysis failed."
      if echo "$INSTRUMENT_OUTPUT" | grep -qi "authentication\|unauthorized\|api key\|401"; then
        echo "Hint: Check your API key — authentication failed."
      elif echo "$INSTRUMENT_OUTPUT" | grep -qi "no such file\|ClassNotFoundException\|NoClassDefFound"; then
        echo "Hint: App may not have the TestPilot SDK installed. Check your build."
      elif echo "$INSTRUMENT_OUTPUT" | grep -qi "INSTRUMENTATION_ABORTED\|process crashed"; then
        echo "Hint: Instrumentation was aborted. Try: adb shell am force-stop $PACKAGE"
      fi
      echo "--- Output ---"
      echo "$INSTRUMENT_OUTPUT"
      exit 1
    fi

    echo "Pulling report..."
    adb pull "/sdcard/Android/data/$PACKAGE/files/testpilot_report.html" "$OUTPUT" \
      || { echo "Error: Could not pull report from device."; exit 1; }

    echo "Report written to: $OUTPUT"
    open "$OUTPUT" 2>/dev/null || echo "Open $OUTPUT in your browser."
  fi

elif [[ "$PLATFORM" == "web" ]]; then
  _ensure_artifact web
  JAVA_BIN="$TESTPILOT_CACHE/web/jre/bin/java"
  WEB_JAR="$TESTPILOT_CACHE/web/testpilot-web.jar"

  WEB_LOG=$(mktemp)
  WEB_EXIT_FILE=$(mktemp)
  trap 'rm -f "$WEB_LOG" "$WEB_EXIT_FILE"' EXIT

  (
    export TESTPILOT_MODE="$COMMAND"
    export TESTPILOT_WEB_URL="$URL"
    export TESTPILOT_OBJECTIVE="$OBJECTIVE"
    export TESTPILOT_API_KEY="$API_KEY"
    export TESTPILOT_PROVIDER="$PROVIDER"
    export TESTPILOT_MAX_STEPS="$MAX_STEPS"
    export TESTPILOT_LANG="$LANG_CODE"
    export TESTPILOT_OUTPUT="$OUTPUT"
    export TESTPILOT_WEB_USERNAME="$USERNAME"
    export TESTPILOT_WEB_PASSWORD="$PASSWORD"
    "$JAVA_BIN" -jar "$WEB_JAR" 2>&1
    echo $? >"$WEB_EXIT_FILE"
  ) | tee "$WEB_LOG"
  RUNNER_EXIT=$(cat "$WEB_EXIT_FILE" 2>/dev/null || echo "1")

  if [[ "$TEST_MODE" == "true" ]]; then
    RESULT_LINE=$(grep "^TESTPILOT_RESULT:" "$WEB_LOG" | tail -1)
    rm -f "$WEB_LOG"
    if [[ -z "$RESULT_LINE" && "$RUNNER_EXIT" -ne 0 ]]; then
      echo "Error: Web runner crashed (exit $RUNNER_EXIT) without producing a result."
      if grep -qi "authentication\|unauthorized\|api key\|401" "$WEB_LOG" 2>/dev/null; then
        echo "Hint: Check your API key — authentication error detected."
      elif grep -qi "net::ERR\|ERR_NAME_NOT_RESOLVED\|page.goto" "$WEB_LOG" 2>/dev/null; then
        echo "Hint: Could not reach the URL. Check --url is accessible and the format is correct."
      fi
      exit 1
    fi
    if [[ "$RESULT_LINE" == "TESTPILOT_RESULT: PASS"* ]]; then
      exit 0
    else
      exit 1
    fi
  else
    if [[ "$RUNNER_EXIT" -ne 0 ]]; then
      echo "Error: Web runner failed (exit $RUNNER_EXIT)."
      if grep -qi "authentication\|unauthorized\|api key\|401" "$WEB_LOG" 2>/dev/null; then
        echo "Hint: Check your API key — authentication error detected."
      elif grep -qi "net::ERR\|ERR_NAME_NOT_RESOLVED\|page.goto" "$WEB_LOG" 2>/dev/null; then
        echo "Hint: Could not reach the URL. Check --url is accessible and the format is correct."
      fi
      rm -f "$WEB_LOG"
      exit 1
    fi
    rm -f "$WEB_LOG"
    echo "Report written to: $OUTPUT"
    open "$OUTPUT" 2>/dev/null || echo "Open $OUTPUT in your browser."
  fi

else
  echo "Error: Unknown platform \"$PLATFORM\". Use ios, android, or web."
  exit 1
fi
