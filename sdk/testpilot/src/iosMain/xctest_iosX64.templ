language = Objective-C
package = platform.XCTest
depends = UIKit
modules = XCTest
linkerOpts= -weak_framework XCTest -L${XCODE_PATH}/Platforms/iPhoneSimulator.platform/Developer/SDKs/iPhoneSimulator.sdk/System/Library/Frameworks/UIKit.framework -F${XCODE_PATH}/Platforms/iPhoneSimulator.platform/Developer/Library/Frameworks/
compilerOpts= -weak_framework XCTest -F${XCODE_PATH}/Platforms/MacOSX.platform/Developer/Library/Frameworks/
